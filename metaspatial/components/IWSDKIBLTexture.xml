<ComponentSchema packageName="com.iwsdk.components">
  <Component name="IBLTexture" description="Image‑based lighting from texture or Room environment">
    <PathByFilePickerAttribute name="src" defaultValue="room" fileTypes=".png,.jpg,.ktx2,.hdr,.exr" subfolder="textures"/>
    <FloatAttribute name="intensity" defaultValue="1f"/>
    <Vector3Attribute name="rotation" defaultValue="0f, 0f, 0f"/>
  </Component>
</ComponentSchema>